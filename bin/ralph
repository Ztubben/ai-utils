#!/usr/bin/env bash
# ralph - the Ralph Loop CLI (shipped from ai-utils, invoked from a superproject).
#
# Subcommands are added as stories land. Today:
#   ralph --init [CONFIG]         Bootstrap the superproject: create the canonical labels + base branch.
#   ralph --check-config [PATH]   Validate .ralph.yml (default ./.ralph.yml) and exit.
#   ralph --lint-story PATH       Validate a canonical Ralph story issue (JSON, or - for stdin).
#   ralph --dry-run [PATH]        Scan the backlog and print the next action, changing nothing.
#   ralph --ready-features [PATH] List PRDs eligible for the Feature completion pass (ADR-0006).
#   ralph --branch-name STORY [CONFIG] [PRD]  Print the working branch per story kind (ADR-0006).
#   ralph --run-gating [CONFIG]   Run the configured gating steps locally, fail-fast.
#   ralph --complete-afk STORY [CONFIG] [PRD]  Complete a green AFK story per story kind (ADR-0006).
#   ralph --complete-hil STORY [CONFIG] [PRD]  Park a green HIL story at awaiting-bench per story kind (ADR-0006).
#   ralph --checkpoint STORY SUMMARY [CONFIG]  Write a Handoff (WIP commits + issue comment) and stop.
#   ralph --resume STORY [CONFIG]  Resume a checkpointed in-progress story (check out its branch).
#   ralph --record-attempt STORY REASON [CONFIG]  Record a failed Attempt; block the story at the limit.
#   ralph --complete-feature PRD [CONFIG]  Integrate a complete Feature into base (ADR-0006).
#   ralph --record-boundary STORY [CONFIG] [PRD] SHA  Record the feature-branch boundary SHA at story start.
#   ralph --reset-on-block STORY REASON [CONFIG] [PRD]  Quarantine a blocked Feature story on a rescue branch.
#   ralph --check-breaker [BACKLOG] [CONFIG]  Trip the circuit breaker (needs-human + tag) if enough stories are blocked.
#   ralph --needs-freshness ISSUE# [BACKLOG]  Print yes/no: does this Feature story need a base merge?
#   ralph --read-learnings DIR [ROOT]  Print the nested AGENTS.md learnings to read at story start.
#   ralph --learn-target PATH [ROOT]   Print the nearest AGENTS.md to promote a learning to.
set -euo pipefail

RALPH_HOME="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

usage() {
  cat <<'EOF'
usage: ralph --init [CONFIG]
       ralph --check-config [PATH]
       ralph --lint-story PATH
       ralph --dry-run [PATH]
       ralph --ready-features [PATH]
       ralph --branch-name STORY [CONFIG] [PRD]
       ralph --run-gating [CONFIG]
       ralph --complete-afk STORY [CONFIG] [PRD]
       ralph --complete-hil STORY [CONFIG] [PRD]
       ralph --complete-feature PRD [CONFIG]
       ralph --checkpoint STORY SUMMARY [CONFIG]
       ralph --resume STORY [CONFIG]
       ralph --record-attempt STORY REASON [CONFIG]
       ralph --record-boundary STORY [CONFIG] [PRD] SHA
       ralph --reset-on-block STORY REASON [CONFIG] [PRD]
       ralph --check-breaker [BACKLOG] [CONFIG]
       ralph --needs-freshness ISSUE# [BACKLOG]
       ralph --read-learnings DIR [ROOT]
       ralph --learn-target PATH [ROOT]

  --init [CONFIG]         Bootstrap the superproject for the Ralph Loop:
                          idempotently create the canonical state:/type:/prio:/
                          needs-human/ready-for-human GitHub labels and, if the
                          configured base branch is missing, create it off the
                          repo's default branch. Reads the base from CONFIG
                          (default .ralph.yml). Safe to re-run. Exits 0 on
                          success, 1 on a git/gh failure, 2 on bad config.
  --check-config [PATH]   Validate a .ralph.yml config against the shipped
                          JSON-schema (default: ./.ralph.yml). Exits 0 on a
                          valid config, non-zero (reporting the offending
                          fields) otherwise.
  --lint-story PATH       Validate a story issue (gh --json shape; PATH may be
                          - for stdin) against the canonical Ralph backlog
                          format. Exits 0 when canonical, non-zero (reporting
                          the offending fields) otherwise.
  --dry-run [PATH]        Scan the backlog and print the next action
                          (resume #N / start #N / no-work / halt) without
                          changing anything. Reads a JSON backlog from PATH
                          (or - for stdin); with no PATH, scans the live
                          backlog via gh.
  --ready-features [PATH] Scan the backlog and print, one per line, the PRD
                          numbers eligible for the Feature completion pass
                          (ADR-0006): open, prd + state:ready, at least one
                          story naming it Parent:, all such stories closed.
                          Reads a JSON backlog from PATH (or - for stdin);
                          with no PATH, scans the live backlog via gh.
  --branch-name STORY     Print the working branch for a story (gh --json; -
       [CONFIG] [PRD]     for stdin), per story kind (ADR-0006). An Orphan
                          Story (Parent: None) resolves via branch_pattern
                          (default ralph/{issue}-{slug}); a Feature story
                          (Parent: #N) resolves via feature_pattern (default
                          feature/{issue}-{slug}) from its PRD issue, given
                          as PRD (gh --json path). CONFIG is optional (pass
                          "" to skip). Exits 2 when a Feature story is given
                          without its PRD context.
  --run-gating [CONFIG]   Run the configured gating steps (default .ralph.yml)
                          locally in order, fail-fast, low-verbosity. Exits 0
                          when all pass, 1 on a gating failure, 2 on bad config.
  --complete-afk STORY    Complete a green AFK story (gh --json shape; - for
       [CONFIG] [PRD]     stdin) per story kind (ADR-0006). An Orphan Story is
                          auto-merged into base per afk_merge and closed; a
                          Feature story (Parent: #N) is pushed to its feature
                          branch (resolved from its PRD issue, given as PRD)
                          and closed -- no PR, no merge. Never touches main.
                          Exits 0 on success, 1 on a git/gh failure, 2 on bad
                          config or a refusal (incl. a Feature story without
                          its PRD context).
  --complete-hil STORY    Park a green HIL story (gh --json shape; - for
       [CONFIG] [PRD]     stdin) at state:awaiting-bench per story kind
                          (ADR-0006). An Orphan Story is pushed to its story
                          branch and PR'd to base; a Feature story (Parent:
                          #N) is pushed to its feature branch (resolved from
                          its PRD issue, given as PRD) with the completion
                          commit SHA recorded as a bench anchor comment -- no
                          PR. Never merges or closes; never touches main.
                          Exits 0 on success, 1 on a git/gh failure, 2 on bad
                          config or a refusal (incl. a Feature story without
                          its PRD context).
  --complete-feature PRD  Integrate a complete Feature (gh --json PRD issue;
       [CONFIG]           path or - for stdin) into base (ADR-0006).
                          Autosquash-collapses fixup! commits (cosmetic
                          fallback on conflict), rebases onto base, runs full
                          gating, opens a single PR and merges with a merge
                          commit (never squash), then closes the PRD. A rebase
                          conflict or red gate pushes the branch, comments
                          details on the PRD, and labels it ready-for-human
                          (no needs-human). Never touches main. Exits 0 on
                          success, 1 on a blocker, 2 on bad config or refusal.
  --checkpoint STORY      Write a Handoff for an in-progress story: commit + push
       SUMMARY [CONFIG]   WIP to the story branch and post an issue comment
                          (carrying the handoff marker) with SUMMARY, then stop.
                          Ralph never compacts context. Never touches base/main.
                          Exits 0 on success, 1 on a git/gh failure, 2 on bad
                          config or a refusal.
  --resume STORY          Resume a checkpointed state:in-progress story: check out
       [CONFIG]           its branch and surface the latest Handoff. Base branch
                          untouched. Exits 0 on success, 1 on a git/gh failure,
                          2 on bad config or a refusal.
  --record-attempt STORY  Record a failed Attempt on a story (gh --json shape; -
       REASON [CONFIG]    for stdin) with a terse REASON. After limits.max_attempts
                          failed Attempts the story moves to state:blocked. A
                          context-full checkpoint is not an Attempt. Exits 0 on
                          success, 1 on a gh failure, 2 on bad config.
  --record-boundary STORY Record the feature-branch boundary SHA at story start
       [CONFIG] [PRD] SHA (gh --json shape; - for stdin). For a Feature story
                          (Parent: #N), posts a boundary comment on the issue
                          recording SHA so reset-on-block can rewind to it. For
                          an Orphan Story, does nothing (exits 0). PRD is the
                          gh --json path for the Feature's PRD issue. Exits 0
                          on success, 1 on a gh failure, 2 on bad config or
                          refusal.
  --reset-on-block STORY  Quarantine a blocked Feature story on a rescue branch
       REASON [CONFIG]    (gh --json shape; - for stdin). Pushes the story's
       [PRD]              work to a rescue branch (rescue_pattern), rewinds the
                          feature branch to the recorded boundary SHA, and posts
                          a demotion comment naming the rescue branch. Orphan
                          Stories are unchanged (exits 0, no commands). Exits 0
                          on success, 1 on a git/gh failure, 2 on bad config
                          or refusal.
  --check-breaker         Trip the circuit breaker if limits.circuit_breaker stories
       [BACKLOG] [CONFIG] are state:blocked: apply needs-human and tag the configured
                          handle, halting the loop. Reads a JSON backlog from BACKLOG
                          (or - for stdin); with no BACKLOG, scans live via gh. Exits
                          0 on success, 1 on a gh failure, 2 on bad config.
  --needs-freshness       Print "yes" or "no": whether a Feature story with
       ISSUE# [BACKLOG]  out-of-Feature dependencies needs a base merge into
                          its feature branch before the iteration starts
                          (ADR-0006). Reads a JSON backlog from BACKLOG (or -
                          for stdin); with no BACKLOG, scans live via gh. An
                          Orphan Story or a story with no out-of-Feature deps
                          always prints "no". Exits 0, or 2 on bad input.
  --read-learnings DIR    Print the nested AGENTS.md learnings (nearest-first,
       [ROOT]             from DIR up to ROOT, default DIR) Ralph reads at the
                          start of a story. Exits 0, or 2 if DIR is missing.
  --learn-target PATH     Print the nearest AGENTS.md a reusable learning for
       [ROOT]             PATH should be promoted to (module-local; a new one in
                          PATH's own directory when none exists up to ROOT,
                          default cwd). Never a progress.txt. Exits 0, or 2 with
                          no PATH.
EOF
}

main() {
  case "${1:-}" in
    --init)
      shift
      exec python3 "$RALPH_HOME/lib/ralph_init.py" init "$@"
      ;;
    --check-config)
      local config="${2:-.ralph.yml}"
      exec python3 "$RALPH_HOME/lib/ralph_config.py" "$config"
      ;;
    --lint-story)
      if [[ -z "${2:-}" ]]; then
        echo "ralph: --lint-story requires a PATH (or - for stdin)" >&2
        exit 2
      fi
      exec python3 "$RALPH_HOME/lib/ralph_story.py" "$2"
      ;;
    --dry-run)
      if [[ -n "${2:-}" ]]; then
        exec python3 "$RALPH_HOME/lib/ralph_select.py" "$2"
      else
        exec python3 "$RALPH_HOME/lib/ralph_select.py"
      fi
      ;;
    --ready-features)
      shift
      exec python3 "$RALPH_HOME/lib/ralph_select.py" ready-features "$@"
      ;;
    --needs-freshness)
      shift
      exec python3 "$RALPH_HOME/lib/ralph_select.py" needs-freshness "$@"
      ;;
    --branch-name)
      shift
      exec python3 "$RALPH_HOME/lib/ralph_iterate.py" branch-name "$@"
      ;;
    --run-gating)
      shift
      exec python3 "$RALPH_HOME/lib/ralph_iterate.py" run-gating "$@"
      ;;
    --complete-afk)
      shift
      exec python3 "$RALPH_HOME/lib/ralph_afk.py" complete "$@"
      ;;
    --complete-hil)
      shift
      exec python3 "$RALPH_HOME/lib/ralph_hil.py" complete "$@"
      ;;
    --complete-feature)
      shift
      exec python3 "$RALPH_HOME/lib/ralph_feature.py" complete "$@"
      ;;
    --checkpoint)
      shift
      exec python3 "$RALPH_HOME/lib/ralph_handoff.py" checkpoint "$@"
      ;;
    --resume)
      shift
      exec python3 "$RALPH_HOME/lib/ralph_handoff.py" resume "$@"
      ;;
    --record-attempt)
      shift
      exec python3 "$RALPH_HOME/lib/ralph_failure.py" record-attempt "$@"
      ;;
    --record-boundary)
      shift
      exec python3 "$RALPH_HOME/lib/ralph_failure.py" record-boundary "$@"
      ;;
    --reset-on-block)
      shift
      exec python3 "$RALPH_HOME/lib/ralph_failure.py" reset-on-block "$@"
      ;;
    --check-breaker)
      shift
      exec python3 "$RALPH_HOME/lib/ralph_failure.py" check-breaker "$@"
      ;;
    --read-learnings)
      shift
      exec python3 "$RALPH_HOME/lib/ralph_memory.py" read-learnings "$@"
      ;;
    --learn-target)
      shift
      exec python3 "$RALPH_HOME/lib/ralph_memory.py" learn-target "$@"
      ;;
    -h|--help|"")
      usage
      ;;
    *)
      echo "ralph: unknown command: $1" >&2
      usage >&2
      exit 2
      ;;
  esac
}

main "$@"
