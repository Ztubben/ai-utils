#!/usr/bin/env bash
# ralph - the Ralph Loop CLI (shipped from ai-utils, invoked from a superproject).
#
# Subcommands are added as stories land. Today:
#   ralph --init [CONFIG]         Bootstrap the superproject: create the canonical labels + base branch.
#   ralph --check-config [PATH]   Validate .ralph.yml (default ./.ralph.yml) and exit.
#   ralph --lint-story PATH       Validate a canonical Ralph story issue (JSON, or - for stdin).
#   ralph --dry-run [PATH]        Scan the backlog and print the next action, changing nothing.
#   ralph --branch-name STORY [CONFIG]  Print the story branch name from branch_pattern.
#   ralph --run-gating [CONFIG]   Run the configured gating steps locally, fail-fast.
#   ralph --complete-afk STORY [CONFIG]  Auto-merge a green AFK story to base + close it.
#   ralph --complete-hil STORY [CONFIG]  Open a PR for a green HIL story + move to awaiting-bench.
#   ralph --checkpoint STORY SUMMARY [CONFIG]  Write a Handoff (WIP commits + issue comment) and stop.
#   ralph --resume STORY [CONFIG]  Resume a checkpointed in-progress story (check out its branch).
#   ralph --record-attempt STORY REASON [CONFIG]  Record a failed Attempt; block the story at the limit.
#   ralph --check-breaker [BACKLOG] [CONFIG]  Trip the circuit breaker (needs-human + tag) if enough stories are blocked.
#   ralph --read-learnings DIR [ROOT]  Print the nested AGENTS.md learnings to read at story start.
#   ralph --learn-target PATH [ROOT]   Print the nearest AGENTS.md to promote a learning to.
set -euo pipefail

RALPH_HOME="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

usage() {
  cat <<'EOF'
usage: ralph --init [CONFIG]
       ralph --check-config [PATH]
       ralph --lint-story PATH
       ralph --dry-run [PATH]
       ralph --branch-name STORY [CONFIG]
       ralph --run-gating [CONFIG]
       ralph --complete-afk STORY [CONFIG]
       ralph --complete-hil STORY [CONFIG]
       ralph --checkpoint STORY SUMMARY [CONFIG]
       ralph --resume STORY [CONFIG]
       ralph --record-attempt STORY REASON [CONFIG]
       ralph --check-breaker [BACKLOG] [CONFIG]
       ralph --read-learnings DIR [ROOT]
       ralph --learn-target PATH [ROOT]

  --init [CONFIG]         Bootstrap the superproject for the Ralph Loop:
                          idempotently create the canonical state:/type:/prio:/
                          needs-human/ready-for-human GitHub labels and, if the
                          configured base branch is missing, create it off the
                          repo's default branch. Reads the base from CONFIG
                          (default .ralph.yml). Safe to re-run. Exits 0 on
                          success, 1 on a git/gh failure, 2 on bad config.
  --check-config [PATH]   Validate a .ralph.yml config against the shipped
                          JSON-schema (default: ./.ralph.yml). Exits 0 on a
                          valid config, non-zero (reporting the offending
                          fields) otherwise.
  --lint-story PATH       Validate a story issue (gh --json shape; PATH may be
                          - for stdin) against the canonical Ralph backlog
                          format. Exits 0 when canonical, non-zero (reporting
                          the offending fields) otherwise.
  --dry-run [PATH]        Scan the backlog and print the next action
                          (resume #N / start #N / no-work / halt) without
                          changing anything. Reads a JSON backlog from PATH
                          (or - for stdin); with no PATH, scans the live
                          backlog via gh.
  --branch-name STORY     Print the story branch name (STORY is a gh --json
       [CONFIG]           story; - for stdin) from the config's branch_pattern
                          (default ralph/{issue}-{slug}). CONFIG is optional.
  --run-gating [CONFIG]   Run the configured gating steps (default .ralph.yml)
                          locally in order, fail-fast, low-verbosity. Exits 0
                          when all pass, 1 on a gating failure, 2 on bad config.
  --complete-afk STORY    Auto-merge a green AFK story (gh --json shape; - for
       [CONFIG]           stdin) into base per afk_merge and close its issue.
                          Never touches main. Exits 0 on success, 1 on a
                          git/gh failure, 2 on bad config or a refusal.
  --complete-hil STORY    Open a PR to base for a green HIL story (gh --json
       [CONFIG]           shape; - for stdin) and move it to
                          state:awaiting-bench. Never merges or closes; never
                          touches main. Exits 0 on success, 1 on a git/gh
                          failure, 2 on bad config or a refusal.
  --checkpoint STORY      Write a Handoff for an in-progress story: commit + push
       SUMMARY [CONFIG]   WIP to the story branch and post an issue comment
                          (carrying the handoff marker) with SUMMARY, then stop.
                          Ralph never compacts context. Never touches base/main.
                          Exits 0 on success, 1 on a git/gh failure, 2 on bad
                          config or a refusal.
  --resume STORY          Resume a checkpointed state:in-progress story: check out
       [CONFIG]           its branch and surface the latest Handoff. Base branch
                          untouched. Exits 0 on success, 1 on a git/gh failure,
                          2 on bad config or a refusal.
  --record-attempt STORY  Record a failed Attempt on a story (gh --json shape; -
       REASON [CONFIG]    for stdin) with a terse REASON. After limits.max_attempts
                          failed Attempts the story moves to state:blocked. A
                          context-full checkpoint is not an Attempt. Exits 0 on
                          success, 1 on a gh failure, 2 on bad config.
  --check-breaker         Trip the circuit breaker if limits.circuit_breaker stories
       [BACKLOG] [CONFIG] are state:blocked: apply needs-human and tag the configured
                          handle, halting the loop. Reads a JSON backlog from BACKLOG
                          (or - for stdin); with no BACKLOG, scans live via gh. Exits
                          0 on success, 1 on a gh failure, 2 on bad config.
  --read-learnings DIR    Print the nested AGENTS.md learnings (nearest-first,
       [ROOT]             from DIR up to ROOT, default DIR) Ralph reads at the
                          start of a story. Exits 0, or 2 if DIR is missing.
  --learn-target PATH     Print the nearest AGENTS.md a reusable learning for
       [ROOT]             PATH should be promoted to (module-local; a new one in
                          PATH's own directory when none exists up to ROOT,
                          default cwd). Never a progress.txt. Exits 0, or 2 with
                          no PATH.
EOF
}

main() {
  case "${1:-}" in
    --init)
      shift
      exec python3 "$RALPH_HOME/lib/ralph_init.py" init "$@"
      ;;
    --check-config)
      local config="${2:-.ralph.yml}"
      exec python3 "$RALPH_HOME/lib/ralph_config.py" "$config"
      ;;
    --lint-story)
      if [[ -z "${2:-}" ]]; then
        echo "ralph: --lint-story requires a PATH (or - for stdin)" >&2
        exit 2
      fi
      exec python3 "$RALPH_HOME/lib/ralph_story.py" "$2"
      ;;
    --dry-run)
      if [[ -n "${2:-}" ]]; then
        exec python3 "$RALPH_HOME/lib/ralph_select.py" "$2"
      else
        exec python3 "$RALPH_HOME/lib/ralph_select.py"
      fi
      ;;
    --branch-name)
      shift
      exec python3 "$RALPH_HOME/lib/ralph_iterate.py" branch-name "$@"
      ;;
    --run-gating)
      shift
      exec python3 "$RALPH_HOME/lib/ralph_iterate.py" run-gating "$@"
      ;;
    --complete-afk)
      shift
      exec python3 "$RALPH_HOME/lib/ralph_afk.py" complete "$@"
      ;;
    --complete-hil)
      shift
      exec python3 "$RALPH_HOME/lib/ralph_hil.py" complete "$@"
      ;;
    --checkpoint)
      shift
      exec python3 "$RALPH_HOME/lib/ralph_handoff.py" checkpoint "$@"
      ;;
    --resume)
      shift
      exec python3 "$RALPH_HOME/lib/ralph_handoff.py" resume "$@"
      ;;
    --record-attempt)
      shift
      exec python3 "$RALPH_HOME/lib/ralph_failure.py" record-attempt "$@"
      ;;
    --check-breaker)
      shift
      exec python3 "$RALPH_HOME/lib/ralph_failure.py" check-breaker "$@"
      ;;
    --read-learnings)
      shift
      exec python3 "$RALPH_HOME/lib/ralph_memory.py" read-learnings "$@"
      ;;
    --learn-target)
      shift
      exec python3 "$RALPH_HOME/lib/ralph_memory.py" learn-target "$@"
      ;;
    -h|--help|"")
      usage
      ;;
    *)
      echo "ralph: unknown command: $1" >&2
      usage >&2
      exit 2
      ;;
  esac
}

main "$@"
